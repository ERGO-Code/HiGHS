## HiGHS CMake configuration file

set(@PACKAGE_PREFIX@_VERSION @PROJECT_VERSION@)

@PACKAGE_INIT@

include(CMakeFindDependencyMacro)
find_dependency(Threads)

# Only look for BLAS if highs was built with it and did not bundle OpenBLAS.
# When BUILD_OPENBLAS=ON, the OpenBLAS target is already in highs-targets.cmake.
set(_HIGHS_HAVE_BLAS @HIPO@)
set(_HIGHS_BUILT_OPENBLAS @BUILD_OPENBLAS@)

if(_HIGHS_HAVE_BLAS AND NOT _HIGHS_BUILT_OPENBLAS)
    find_dependency(BLAS)
endif()

# Let users know about optional features
set(HIGHS_HAVE_BLAS ${_HIGHS_HAVE_BLAS})

@CONF_ZLIB@

include("${CMAKE_CURRENT_LIST_DIR}/highs-targets.cmake")
